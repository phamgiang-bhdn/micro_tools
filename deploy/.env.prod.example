# Copy file này thành .env.prod ở thư mục gốc, điền giá trị, rồi:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ----- Database -----
DB_USER=dealvault
DB_PASSWORD=replace-with-strong-password
DB_NAME=dealvault

# ----- Public URL -----
SITE_URL=https://yourdomain.com

# ----- Secrets -----
GEMINI_API_KEY=your-gemini-api-key
ADMIN_API_KEY=replace-with-long-random-string

# ----- Affiliate networks -----
ACCESSTRADE_API_BASE=https://api.accesstrade.vn/v1
ACCESSTRADE_ACCESS_TOKEN=
ACCESSTRADE_PUBLISHER_ID=

SHOPEE_AFFILIATE_APP_ID=
SHOPEE_AFFILIATE_APP_SECRET=

# ----- Crawler -----
CRAWLER_ENABLED=true
CRAWLER_CRON=0 */6 * * *
CRAWLER_MIN_DISCOUNT_PERCENT=20
CRAWLER_AI_ENRICH=true
