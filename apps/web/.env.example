# Next.js dev/prod local port (khớp với apps/web/package.json script dev/start)
PORT=3100

# Backend API base URL
API_BASE_URL="http://localhost:4000/api/v1"

# Admin role used by dashboard when calling admin endpoints
# Allowed: viewer | reviewer | admin
ADMIN_ROLE="admin"

# Must be exactly the same as apps/api/.env -> ADMIN_API_KEY
ADMIN_API_KEY="change-this-to-a-long-random-secret"
