DATABASE_URL="postgresql://affiliate_admin:affiliate_password@localhost:5432/affiliate_platform?schema=public"

ADMIN_API_KEY="change-this-to-a-long-random-secret"

# Default: DeepSeek V3 — rẻ (~$0.27/$1.10 per 1M token), JSON mode ổn định,
# tiếng Việt tốt, có prompt cache tự động (hit ~$0.027 — giảm 90% chi phí prefix lặp).
# Đổi sang Qwen/Moonshot/GLM/OpenRouter: cùng env, chỉ đổi AI_BASE_URL + AI_MODEL.
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat

# Legacy: Gemini fallback. Để chuyển về, set AI_PROVIDER=gemini.
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"

# AI call timeout per stage (ms). Bị treo quá ngưỡng → throw transient error, runner mark FAILED.
# DeepSeek thường 15-40s/call cho output JSON 1-3K tokens. Bump nếu prompt cache miss.
# Đặt = 0 (hoặc số âm) để TẮT timeout hẳn — admin tự đợi, không bị cắt giữa chừng.
AI_DEFAULT_TIMEOUT_MS=90000
AI_BRIEF_TIMEOUT_MS=90000
AI_OUTLINE_TIMEOUT_MS=90000
AI_WRITER_TIMEOUT_MS=120000

TAVILY_API_KEY=

ACCESSTRADE_ACCESS_TOKEN=""

# === Backbone sync mode (at-money-flows-v1 STORY-02) ===
# 4 cron backbone OFF mặc định — operator chạy manual qua admin button "Đồng bộ tất cả".
# Khi muốn bật cron tự chạy 24/7: set true (cần hosting tier hỗ trợ background process).
CRAWLER_ENABLED=false
RECONCILE_ENABLED=false
COUPON_SYNC_ENABLED=false
TOP_PRODUCTS_ENABLED=false

# Tần suất cron khi enabled (ko ảnh hưởng manual mode).
CRAWLER_CRON=0 */6 * * *
RECONCILE_CRON=*/30 * * * *
COUPON_SYNC_CRON=0 */6 * * *
TOP_PRODUCTS_CRON=0 3 * * *

# === Refinery v2 (at-money-flows-v1 STORY-09) ===
# Product có confidence ≥ ngưỡng → auto-flip Product.isPublic=true + ProductExtraction.status=PUBLISHED.
# Operator vẫn có 24h soft un-approve qua /admin/refinery tab "Tự auto-duyệt".
REFINERY_AUTO_APPROVE_THRESHOLD=80

# === Article wizard notification (STORY-10) ===
# Email recipient cho notification khi article AI tạo xong.
# Placeholder log nếu EMAIL_PROVIDER chưa setup.
ADMIN_EMAIL=
SITE_URL=http://localhost:3100
EMAIL_PROVIDER=
RESEND_API_KEY=
