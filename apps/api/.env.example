# PostgreSQL connection string (docker-compose default)
DATABASE_URL="postgresql://affiliate_admin:affiliate_password@localhost:5432/affiliate_platform?schema=public"

# API server port
PORT=4000

# Google Gemini API key (required for AI parser + crawler enrichment)
GEMINI_API_KEY="your-gemini-api-key"

# Gemini model name. Defaults to gemini-2.0-flash if unset.
# Common choices:
#   gemini-2.0-flash               — fast & cheap, good for extraction (default)
#   gemini-2.0-flash-thinking-exp  — slower, reasons before answering, for messy raw content
#   gemini-2.0-pro                 — highest accuracy, more expensive
GEMINI_MODEL="gemini-2.0-flash"

# Secret key to protect admin endpoints (must match apps/web/.env -> ADMIN_API_KEY)
ADMIN_API_KEY="change-this-to-a-long-random-secret"

# ----- Article AI authoring -----
# Domains AI may "discover" products from during article generation (comma-separated).
# Products outside this whitelist are rejected before scraping.
ALLOWED_PRODUCT_DOMAINS="shopee.vn,tiki.vn,lazada.vn,fptshop.com.vn,thegioididong.com,dienmayxanh.com"
# Set "false" to disable Gemini Google Search grounding (cheaper, no fresh-web discovery).
ARTICLE_GROUNDING=true

# ----- Crawler -----
# Set false to disable the cron tick entirely (manual /admin/crawler/run still works).
CRAWLER_ENABLED=true
# Cron expression for periodic crawl. Default: every 6 hours.
CRAWLER_CRON="0 */6 * * *"
# Set to "false" to skip AI rewriting of name/description/highlights.
CRAWLER_AI_ENRICH=true
# Comma-separated affiliate networks to actually pull from (case-insensitive).
# Default = accesstrade only. Other clients (SHOPEE/LAZADA/TIKTOK) stay registered
# but won't be called. Add when you've onboarded direct integration with that network.
CRAWLER_ENABLED_NETWORKS=accesstrade

# ----- Top Products -----
# Set false to disable daily top-products snapshot (manual /admin/top-products/sync still works).
TOP_PRODUCTS_ENABLED=true
# Cron expression. Default: 3am daily.
TOP_PRODUCTS_CRON="0 3 * * *"

# ----- Coupon Sync -----
# Set false to disable scheduled coupon sync (manual /admin/coupons/sync-from-at still works).
COUPON_SYNC_ENABLED=true
# Cron expression. Default: every 6 hours.
COUPON_SYNC_CRON="0 */6 * * *"

# ----- Reconciliation -----
# Set false to disable scheduled reconciliation (manual /admin/reconciliation/run still works).
RECONCILE_ENABLED=true
# Cron expression. Default: every 30 minutes.
RECONCILE_CRON="*/30 * * * *"

# ----- Accesstrade Publisher (Datafeed API) -----
ACCESSTRADE_API_BASE="https://api.accesstrade.vn/v1"
ACCESSTRADE_ACCESS_TOKEN=""
ACCESSTRADE_PUBLISHER_ID=""

# ----- Shopee Affiliate (Open API) — STUB, not yet implemented -----
SHOPEE_AFFILIATE_APP_ID=""
SHOPEE_AFFILIATE_APP_SECRET=""

# ----- TikTok Shop Affiliate — STUB, not yet implemented -----
TIKTOK_AFFILIATE_APP_KEY=""
TIKTOK_AFFILIATE_APP_SECRET=""

# ----- Lazada Affiliate (Open Platform) — STUB, not yet implemented -----
LAZADA_AFFILIATE_APP_KEY=""
LAZADA_AFFILIATE_APP_SECRET=""
