generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NicheStatus {
  ACTIVE
  INACTIVE
}

enum ParseStatus {
  DRAFT_RAW
  PENDING_REVIEW
  PUBLISHED
  ERROR
}

enum ArticleType {
  BUYING_GUIDE
  REVIEW
}

enum ArticleStatus {
  GENERATING
  DRAFT
  PUBLISHED
  ARCHIVED
  FAILED
}

enum AffiliateNetwork {
  ACCESSTRADE
  SHOPEE
  TIKTOK
  LAZADA
}

enum CampaignStatus {
  APPLIED
  APPROVED
  REJECTED
  PAUSED
  INACTIVE
}

model CrawlerLog {
  id            String   @id @default(uuid()) @db.Uuid
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  fetched       Int      @default(0)
  passedFilter  Int      @default(0)
  created       Int      @default(0)
  updated       Int      @default(0)
  skipped       Int      @default(0)
  success       Boolean  @default(false)
  errorReason   String?
  durationMs    Int?
  triggeredBy   String?

  @@index([startedAt])
}

/// Campaign = mỗi merchant trên một affiliate network (Accesstrade Shopee CPS, Lazada CPS...).
/// Cron crawler tự upsert khi gặp campaign mới trong datafeed (status = APPLIED mặc định).
/// Admin sync tay status APPROVED/REJECTED/PAUSED dựa trên dashboard publisher của network.
model Campaign {
  id              String              @id @default(uuid()) @db.Uuid
  network         AffiliateNetwork
  /// @deprecated dùng atCampaignId thay thế (sprint at-source-of-truth STORY-02).
  /// Giữ để backward compat với row legacy (campaign tạo trước sprint, externalId = slugify(name)).
  /// Khi tất cả campaign đã backfill atCampaignId → cân nhắc drop (xem docs/sprints/at-source-of-truth/FUTURE-DROPS.md).
  externalId      String
  name            String
  merchantName    String?
  status          CampaignStatus      @default(APPLIED)
  appliedAt       DateTime?
  approvedAt      DateTime?
  commissionNote  String?
  notes           String?
  atCampaignId        String?    @unique
  atCategoryName      String?
  atSubCategory       String?
  atLogo              String?
  atMerchantUrl       String?
  atScope             String?
  atCookieDurationSec Int?
  atStartTime         DateTime?
  atEndTime           DateTime?
  atRawData           Json?      @db.JsonB
  atLastSyncedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  assignments     CampaignNiche[]
  products        Product[]
  conversions     ConversionWebhook[]
  coupons         Coupon[]

  @@unique([network, externalId])
  @@index([status])
  @@index([network, status])
  @@index([atCampaignId])
}

/// N:N join giữa Campaign (upstream AT merchant) và Niche (presentation/SEO layer).
/// Mỗi cặp có filterRules + priority riêng. First-match-wins ở crawler: sort theo priority asc,
/// offer pass filterRules đầu tiên → gắn vào Niche của cặp đó.
model CampaignNiche {
  id           String   @id @default(uuid()) @db.Uuid
  campaignId   String   @db.Uuid
  nicheId      String   @db.Uuid
  /// Per-pair filter rules (zod `filterRulesSchema` ở dto/filter-rules.dto.ts).
  filterRules  Json     @db.JsonB
  /// Lower number = match trước. Default 100. Khi 1 offer match nhiều assignment của cùng campaign → assignment priority thấp nhất thắng.
  priority     Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  niche        Niche    @relation(fields: [nicheId], references: [id], onDelete: Cascade)

  @@unique([campaignId, nicheId])
  @@index([campaignId, priority])
  @@index([nicheId])
}

model Coupon {
  id              String          @id @default(uuid()) @db.Uuid
  code            String          @unique
  description     String?
  discountPercent Int?
  discountAmount  Decimal?        @db.Decimal(10, 2)
  network         AffiliateNetwork?
  productId       String?         @db.Uuid
  nicheId         String?         @db.Uuid
  campaignId      String?         @db.Uuid
  affiliateUrl    String?
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean         @default(true)
  atCouponId      String?         @unique
  merchantSlug    String?
  merchantDisplay String?
  merchantLogo    String?
  iconText        String?
  iconTextId      String?
  contentHtml     String?
  imageUrl        String?
  bannersJson     Json?           @db.JsonB
  domain          String?
  prodLink        String?
  coinCap         Decimal?        @db.Decimal(15, 2)
  coinPercentage  Decimal?        @db.Decimal(5, 2)
  percentageUsed  Decimal?        @db.Decimal(5, 2)
  atRawData       Json?           @db.JsonB
  atLastSyncedAt  DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  niche           Niche?          @relation(fields: [nicheId], references: [id], onDelete: SetNull)
  campaign        Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([isActive, expiresAt])
  @@index([nicheId, isActive])
  @@index([productId, isActive])
  @@index([merchantSlug, isActive])
  @@index([atLastSyncedAt])
  @@index([campaignId])
}

model Niche {
  id              String      @id @default(uuid()) @db.Uuid
  slug            String      @unique
  name            String
  status          NicheStatus @default(ACTIVE)
  schemaConfig    Json
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  products        Product[]
  articles        Article[]
  coupons         Coupon[]
  campaignAssignments CampaignNiche[]
}

model Product {
  id           String     @id @default(uuid()) @db.Uuid
  nicheId      String     @db.Uuid
  network      AffiliateNetwork @default(ACCESSTRADE)
  campaignId   String?    @db.Uuid
  name         String
  slug         String?
  affiliateUrl String
  scrapedData  Json       @db.JsonB
  isPublic     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  niche        Niche      @relation(fields: [nicheId], references: [id], onDelete: Cascade)
  campaign     Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  clickLogs    ClickLog[]
  extractions  ProductExtraction[]
  coupons      Coupon[]

  @@unique([nicheId, slug])
  @@index([nicheId])
  @@index([campaignId])
}

model ClickLog {
  id              String              @id @default(uuid()) @db.Uuid
  productId       String              @db.Uuid
  trackingCode    String              @unique
  ipHash          String
  userAgent       String?
  createdAt       DateTime            @default(now())
  product         Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  conversionHooks ConversionWebhook[]

  @@index([productId, createdAt])
}

model ConversionWebhook {
  id               String           @id @default(uuid()) @db.Uuid
  trackingCode     String
  network          AffiliateNetwork @default(ACCESSTRADE)
  campaignId       String?          @db.Uuid
  revenue          Decimal          @db.Decimal(10, 2)
  status           String
  payload          Json             @db.JsonB
  source           String?          @default("webhook")
  lastReconciledAt DateTime?
  atOrderId        String?
  atCommission     Decimal?         @db.Decimal(10, 2)
  reconcileNotes   String?
  receivedAt       DateTime         @default(now())
  clickLog         ClickLog         @relation(fields: [trackingCode], references: [trackingCode], onDelete: Restrict)
  campaign         Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([trackingCode, receivedAt])
  @@index([network, receivedAt])
  @@index([campaignId, receivedAt])
  @@index([atOrderId])
  @@index([lastReconciledAt])
}

model TopProductSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  snapshotDate    DateTime
  position        Int
  atProductId     String
  name            String
  brand           String?
  image           String?
  link            String
  affLink         String
  categoryName    String?
  productCategory String?
  price           Decimal?  @db.Decimal(15, 2)
  discount        Decimal?  @db.Decimal(15, 2)
  merchant        String?
  shortDesc       String?
  atRawData       Json?     @db.JsonB
  createdAt       DateTime  @default(now())

  @@unique([snapshotDate, position, atProductId])
  @@index([snapshotDate])
  @@index([merchant, snapshotDate])
}

model ReconciliationLog {
  id              String   @id @default(uuid()) @db.Uuid
  triggeredBy     String
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  syncWindowStart DateTime
  syncWindowEnd   DateTime
  fetched         Int      @default(0)
  matched         Int      @default(0)
  updated         Int      @default(0)
  unmatched       Int      @default(0)
  success         Boolean  @default(false)
  errorReason     String?
  durationMs      Int?

  @@index([startedAt])
}

model ProductExtraction {
  id              String      @id @default(uuid()) @db.Uuid
  productId       String      @db.Uuid
  rawContent      String
  aiOutput        Json?       @db.JsonB
  status          ParseStatus @default(DRAFT_RAW)
  errorReason     String?
  reviewedBy      String?
  reviewedAt      DateTime?
  sourceUrl       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, status, createdAt])
}

model PromptTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  content     String
  isActive    Boolean  @default(false)
  version     Int      @default(1)
  createdBy   String?
  createdAt   DateTime @default(now())
  activatedAt DateTime?
}

model Article {
  id              String        @id @default(uuid()) @db.Uuid
  slug            String        @unique
  title           String
  excerpt         String?
  body            String
  blocks          Json?         @db.JsonB
  coverImage      String?
  type            ArticleType
  status          ArticleStatus @default(DRAFT)
  nicheId         String?       @db.Uuid
  productIds      String[]      @db.Uuid
  pinnedProductIds String[]     @db.Uuid
  metaTitle       String?
  metaDescription String?
  aiModel         String?
  aiPromptName    String?
  generationError String?
  reviewedBy      String?
  reviewedAt      DateTime?
  scheduledAt     DateTime?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  niche           Niche?        @relation(fields: [nicheId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([nicheId, status])
  @@index([type, status])
  @@index([scheduledAt])
}
