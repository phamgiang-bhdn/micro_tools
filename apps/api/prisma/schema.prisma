generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NicheStatus {
  ACTIVE
  INACTIVE
}

enum ParseStatus {
  DRAFT_RAW
  PENDING_REVIEW
  PUBLISHED
  ERROR
}

enum ArticleType {
  BUYING_GUIDE
  REVIEW
}

enum ArticleStatus {
  // Legacy (kept for backward compat with v1 articles)
  GENERATING
  DRAFT
  // V2 pipeline states
  DRAFT_BRIEF
  RESEARCHING
  REVIEWS_SCRAPED
  OUTLINE_READY
  IMAGES_READY
  DRAFTING
  SELF_CRITIQUED
  FACT_CHECKED
  PENDING_REVIEW
  NEEDS_REVISION
  // Terminal
  PUBLISHED
  ARCHIVED
  FAILED
}

enum EvidenceType {
  FACT
  REVIEW
  PRICE
  SPEC
  IMAGE
  NEWS
}

enum AffiliateNetwork {
  ACCESSTRADE
  SHOPEE
  TIKTOK
  LAZADA
}

enum CampaignStatus {
  APPLIED
  APPROVED
  REJECTED
  PAUSED
  INACTIVE
}

model CrawlerLog {
  id           String    @id @default(uuid()) @db.Uuid
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  fetched      Int       @default(0)
  passedFilter Int       @default(0)
  created      Int       @default(0)
  updated      Int       @default(0)
  skipped      Int       @default(0)
  success      Boolean   @default(false)
  errorReason  String?
  durationMs   Int?
  triggeredBy  String?

  @@index([startedAt])
}

/// Campaign = mỗi merchant trên một affiliate network (Accesstrade Shopee CPS, Lazada CPS...).
/// Cron crawler tự upsert khi gặp campaign mới trong datafeed (status = APPLIED mặc định).
/// Admin sync tay status APPROVED/REJECTED/PAUSED dựa trên dashboard publisher của network.
model Campaign {
  id                  String              @id @default(uuid()) @db.Uuid
  network             AffiliateNetwork
  /// @deprecated dùng atCampaignId thay thế (sprint at-source-of-truth STORY-02).
  /// Giữ để backward compat với row legacy (campaign tạo trước sprint, externalId = slugify(name)).
  /// Khi tất cả campaign đã backfill atCampaignId → cân nhắc drop (xem docs/sprints/at-source-of-truth/FUTURE-DROPS.md).
  externalId          String
  name                String
  merchantName        String?
  status              CampaignStatus      @default(APPLIED)
  appliedAt           DateTime?
  approvedAt          DateTime?
  commissionNote      String?
  notes               String?
  atCampaignId        String?             @unique
  atCategoryName      String?
  atSubCategory       String?
  atLogo              String?
  atMerchantUrl       String?
  atScope             String?
  atCookieDurationSec Int?
  atStartTime         DateTime?
  atEndTime           DateTime?
  atRawData           Json?               @db.JsonB
  atLastSyncedAt      DateTime?
  /// Per-campaign filter rules. Validate qua `filterRulesSchema`.
  /// Khi null/empty → crawler dùng DEFAULT_FILTER_RULES.
  filterRules         Json?               @db.JsonB
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  products            Product[]
  conversions         ConversionWebhook[]
  coupons             Coupon[]

  @@unique([network, externalId])
  @@index([status])
  @@index([network, status])
  @@index([atCampaignId])
}

model Coupon {
  id              String            @id @default(uuid()) @db.Uuid
  code            String            @unique
  description     String?
  discountPercent Int?
  discountAmount  Decimal?          @db.Decimal(10, 2)
  network         AffiliateNetwork?
  productId       String?           @db.Uuid
  nicheId         String?           @db.Uuid
  campaignId      String?           @db.Uuid
  affiliateUrl    String?
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean           @default(true)
  atCouponId      String?           @unique
  merchantSlug    String?
  merchantDisplay String?
  merchantLogo    String?
  iconText        String?
  iconTextId      String?
  contentHtml     String?
  imageUrl        String?
  bannersJson     Json?             @db.JsonB
  domain          String?
  prodLink        String?
  coinCap         Decimal?          @db.Decimal(15, 2)
  coinPercentage  Decimal?          @db.Decimal(5, 2)
  percentageUsed  Decimal?          @db.Decimal(5, 2)
  atRawData       Json?             @db.JsonB
  atLastSyncedAt  DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  product         Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  niche           Niche?            @relation(fields: [nicheId], references: [id], onDelete: SetNull)
  campaign        Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([isActive, expiresAt])
  @@index([nicheId, isActive])
  @@index([productId, isActive])
  @@index([merchantSlug, isActive])
  @@index([atLastSyncedAt])
  @@index([campaignId])
}

model Niche {
  id             String              @id @default(uuid()) @db.Uuid
  slug           String              @unique
  name           String
  status         NicheStatus         @default(ACTIVE)
  schemaConfig   Json
  /// V4: từ khoá phân loại offer thô từ Accesstrade vào niche này (tier-1 keyword match).
  /// Rỗng → service tự suy từ name/slug. Chỉ match với niche ACTIVE → lọc đống merchant-wide.
  keywords       String[]            @default([])
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  products       Product[]
  articles       Article[]
  coupons        Coupon[]
  /// TOOL: tools thuộc về niche này (vd "Chọn máy lọc nước"). Mỗi niche có 0-N tool.
  tools          Tool[]
  /// TOOL: waitlist signup cho niche pre-launch (Epic 0).
  waitlistSignups WaitlistSignup[]
}

/// AT taxonomy bucket — auto-populated từ `offer.atCategorySlug` (raw AT `cate`).
/// Shop — admin tự tạo + gán tay cho từng Product (AT KHÔNG trả shop info).
/// Khác Domain (Brand): Domain là technical (auto từ offer.domain); Shop là cửa hàng cụ thể admin quản lý.
/// Hiển thị trên storefront thay cho campaign info.
model Shop {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique
  name        String
  description String?
  logoUrl     String?
  websiteUrl  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id            String              @id @default(uuid()) @db.Uuid
  /// Niche assigned by admin (PR4 — manual gán tay). NULL = chưa gán → ẩn khỏi storefront.
  /// Crawler KHÔNG tự gán nicheId; admin assign trong /admin/products (bulk hoặc per-row).
  nicheId       String?             @db.Uuid
  /// Shop — admin gán tay (AT không trả). NULL = chưa gán.
  shopId        String?             @db.Uuid
  network       AffiliateNetwork    @default(ACCESSTRADE)
  campaignId    String?             @db.Uuid
  name          String
  slug          String?
  affiliateUrl  String
  scrapedData   Json                @db.JsonB
  /// V4: derived price-intelligence summary (verdict giá thật/ảo/đáy + lowest/avg). Recompute mỗi
  /// crawl cycle từ PriceSnapshot → niche grid đọc free, KHÔNG query snapshot per-card. Shape: PriceIntel.
  priceIntel    Json?               @db.JsonB
  isPublic      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  niche         Niche?              @relation(fields: [nicheId], references: [id], onDelete: SetNull)
  shop          Shop?               @relation(fields: [shopId], references: [id], onDelete: SetNull)
  campaign      Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  clickLogs     ClickLog[]
  extractions   ProductExtraction[]
  coupons       Coupon[]
  reviews       ProductReview[]
  /// STORY-05: matched order-product lines.
  orderProducts OrderProduct[]
  /// V4: chuỗi giá theo thời gian (nền cho verdict + chart).
  priceSnapshots PriceSnapshot[]
  /// V4: đăng ký theo dõi giá xuống (Phase 2).
  priceAlerts   PriceAlert[]

  @@unique([nicheId, slug])
  @@index([nicheId])
  @@index([campaignId])
  @@index([shopId])
}

model ClickLog {
  id                String              @id @default(uuid()) @db.Uuid
  productId         String              @db.Uuid
  trackingCode      String              @unique
  ipHash            String
  userAgent         String?
  /// STORY-06: channel attribution gắn lúc click. "organic" | "fb" | "zalo" | "email" | "direct" | "other".
  channel           String?             @default("direct")
  subId1            String?
  subId2            String?
  attributionSource String?
  /// STORY-07: A/B uplift signal — true nếu card render coupon inline pill khi click.
  hasInlineCoupon   Boolean             @default(false)
  /// TOOL: Tool nào sinh ra click này (null = direct product click, không qua Tool).
  toolId            String?             @db.Uuid
  /// TOOL: QuizSession user click từ. Cho phép trace full funnel quiz → click → conversion.
  quizSessionId     String?             @db.Uuid
  /// TOOL: Sàn user chọn click (tiki | shopee | lazada | tiktokshop). Cho multi-network price compare.
  marketplace       String?
  createdAt         DateTime            @default(now())
  product           Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  tool              Tool?               @relation(fields: [toolId], references: [id], onDelete: SetNull)
  quizSession       QuizSession?        @relation(fields: [quizSessionId], references: [id], onDelete: SetNull)
  conversionHooks   ConversionWebhook[]

  @@index([productId, createdAt])
  @@index([channel])
  @@index([createdAt, channel])
  @@index([toolId, createdAt])
  @@index([quizSessionId])
}

model ConversionWebhook {
  id               String           @id @default(uuid()) @db.Uuid
  trackingCode     String
  network          AffiliateNetwork @default(ACCESSTRADE)
  campaignId       String?          @db.Uuid
  revenue          Decimal          @db.Decimal(10, 2)
  status           String
  payload          Json             @db.JsonB
  source           String?          @default("webhook")
  lastReconciledAt DateTime?
  atOrderId        String?
  atCommission     Decimal?         @db.Decimal(10, 2)
  reconcileNotes   String?
  /// STORY-06: channel attributed from ClickLog (first-touch). Mặc định "direct".
  channel          String?
  receivedAt       DateTime         @default(now())
  clickLog         ClickLog         @relation(fields: [trackingCode], references: [trackingCode], onDelete: Restrict)
  campaign         Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  /// STORY-05: per-order product lines pulled from AT /v1/order-products.
  orderProducts    OrderProduct[]

  @@index([trackingCode, receivedAt])
  @@index([network, receivedAt])
  @@index([campaignId, receivedAt])
  @@index([atOrderId])
  @@index([lastReconciledAt])
  @@index([channel])
  @@index([receivedAt, channel])
}

model TopProductSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  snapshotDate    DateTime
  position        Int
  atProductId     String
  name            String
  brand           String?
  image           String?
  link            String
  affLink         String
  categoryName    String?
  productCategory String?
  price           Decimal? @db.Decimal(15, 2)
  discount        Decimal? @db.Decimal(15, 2)
  merchant        String?
  shortDesc       String?
  atRawData       Json?    @db.JsonB
  createdAt       DateTime @default(now())

  @@unique([snapshotDate, position, atProductId])
  @@index([snapshotDate])
  @@index([merchant, snapshotDate])
}

model ReconciliationLog {
  id              String    @id @default(uuid()) @db.Uuid
  triggeredBy     String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  syncWindowStart DateTime
  syncWindowEnd   DateTime
  fetched         Int       @default(0)
  matched         Int       @default(0)
  updated         Int       @default(0)
  unmatched       Int       @default(0)
  success         Boolean   @default(false)
  errorReason     String?
  durationMs      Int?

  @@index([startedAt])
}

model ProductExtraction {
  id                String      @id @default(uuid()) @db.Uuid
  productId         String      @db.Uuid
  rawContent        String
  aiOutput          Json?       @db.JsonB
  status            ParseStatus @default(DRAFT_RAW)
  errorReason       String?
  reviewedBy        String?
  reviewedAt        DateTime?
  sourceUrl         String?
  /// STORY-09: confidence score 0-100 + lý do. Auto-approve khi >= REFINERY_AUTO_APPROVE_THRESHOLD (default 80).
  confidenceScore   Int?
  confidenceReasons Json?       @db.JsonB
  autoApproved      Boolean     @default(false)
  autoApprovedAt    DateTime?
  /// Operator un-approve trong 24h sau auto-approve. NULL = chưa un-approve.
  unapprovedAt      DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  product           Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, status, createdAt])
  @@index([confidenceScore])
  @@index([autoApproved])
}

model PromptTemplate {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  content     String
  isActive    Boolean   @default(false)
  version     Int       @default(1)
  createdBy   String?
  createdAt   DateTime  @default(now())
  activatedAt DateTime?
}

model Article {
  id                    String                 @id @default(uuid()) @db.Uuid
  slug                  String                 @unique
  title                 String
  excerpt               String?
  body                  String
  blocks                Json?                  @db.JsonB
  coverImage            String?
  type                  ArticleType
  status                ArticleStatus          @default(DRAFT)
  nicheId               String?                @db.Uuid
  productIds            String[]               @db.Uuid
  pinnedProductIds      String[]               @db.Uuid
  metaTitle             String?
  metaDescription       String?
  aiModel               String?
  aiPromptName          String?
  generationError       String?
  reviewedBy            String?
  reviewedAt            DateTime?
  scheduledAt           DateTime?
  publishedAt           DateTime?
  // V2 pipeline fields
  briefJson             Json?                  @db.JsonB
  outlineJson           Json?                  @db.JsonB
  authorId              String?                @db.Uuid
  layoutVariant         String?
  wordCount             Int?
  readabilityScore      Float?
  evidenceFreshAt       DateTime?
  revisionCount         Int                    @default(0)
  aiRevisionCount       Int                    @default(0)
  thesisEmbedding       Float[]
  coverImageAttribution Json?                  @db.JsonB
  currentStageMessage   String?
  currentStageProgress  Int?
  currentStageStartedAt DateTime?
  /// Khi true: pipeline dừng sau OUTLINE (status=IMAGES_READY) để admin duyệt/sửa outline
  /// trước khi tốn 5-10 phút Writer chạy. Admin bấm "Tiếp tục viết" → set false + tiếp tục.
  pauseAtOutline        Boolean                @default(false)
  topic                 String?
  productRef            String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  niche                 Niche?                 @relation(fields: [nicheId], references: [id], onDelete: SetNull)
  author                Author?                @relation(fields: [authorId], references: [id], onDelete: SetNull)
  sections              ArticleSection[]
  evidence              ArticleEvidence[]
  runs                  ArticleGenerationRun[]

  @@index([status, publishedAt])
  @@index([nicheId, status])
  @@index([type, status])
  @@index([scheduledAt])
  @@index([authorId])
  @@index([evidenceFreshAt])
}

/// Author — định danh tác giả của Article V2. voiceProfile (Json) inject vào Writer prompt
/// để chống mono-voice. expertiseNiches dùng cho round-robin rotation.
model Author {
  id              String    @id @default(uuid()) @db.Uuid
  slug            String    @unique
  name            String
  bio             String?
  avatarUrl       String?
  voiceProfile    Json      @db.JsonB
  expertiseNiches String[]  @db.Uuid
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  articles        Article[]

  @@index([isActive])
}

/// ArticleSection — đơn vị tổ chức bài V2. Article có nhiều section, mỗi section là khối
/// blocks (giống schema cũ) + summary cho TOC + evidence refs. Render storefront chia section
/// có anchor để TOC nhảy. Status per-section cho HITL approve granular.
model ArticleSection {
  id             String   @id @default(uuid()) @db.Uuid
  articleId      String   @db.Uuid
  anchorSlug     String
  heading        String
  summary        String
  intent         String?
  order          Int
  blocks         Json     @db.JsonB
  blockTypeHints String[]
  evidenceRefs   String[] @db.Uuid
  wordCount      Int      @default(0)
  estimatedWords Int      @default(0)
  isRequired     Boolean  @default(true)
  status         String   @default("DRAFTING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  article        Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, anchorSlug])
  @@index([articleId, order])
}

/// ArticleEvidence — moat chính chống thin-content. Mỗi claim/fact/review/price/image phải
/// có evidence cite được. Fact-check loop verify sourceUrl còn live và content khớp.
model ArticleEvidence {
  id              String       @id @default(uuid()) @db.Uuid
  articleId       String       @db.Uuid
  type            EvidenceType
  productId       String?      @db.Uuid
  sourceUrl       String
  sourceDomain    String
  title           String?
  payload         Json         @db.JsonB
  contentHash     String
  fetchedAt       DateTime     @default(now())
  expiresAt       DateTime?
  factCheckPassed Boolean      @default(false)
  factCheckedAt   DateTime?
  article         Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, type])
  @@index([contentHash])
  @@index([sourceDomain])
  @@index([productId])
}

/// ProductReview — user review thật cào từ Accesstrade / Shopee / Tiki / Lazada.
/// Đây là "original research signal" cho EEAT. Article có thể cite vào block review_quote.
model ProductReview {
  id            String    @id @default(uuid()) @db.Uuid
  productId     String    @db.Uuid
  source        String
  sourceUrl     String?
  author        String?
  rating        Decimal?  @db.Decimal(3, 2)
  title         String?
  body          String
  verifiedBuyer Boolean   @default(false)
  reviewDate    DateTime?
  scrapedAt     DateTime  @default(now())
  sentiment     String?
  topicTags     String[]
  raw           Json?     @db.JsonB
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, source])
  @@index([productId, rating])
  @@index([productId, sentiment])
}

/// ArticleGenerationRun — observability log per stage execution. Cho phép retry stage lẻ,
/// debug cost, track duration. Inspect qua admin dashboard.
model ArticleGenerationRun {
  id           String    @id @default(uuid()) @db.Uuid
  articleId    String    @db.Uuid
  stage        String
  agent        String
  model        String?
  promptName   String?
  inputHash    String?
  inputSize    Int?
  outputSize   Int?
  output       Json?     @db.JsonB
  durationMs   Int?
  costEstimate Decimal?  @db.Decimal(10, 6)
  success      Boolean   @default(false)
  errorReason  String?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  article      Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, startedAt])
  @@index([stage, success])
}

enum SubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

model Subscriber {
  id              String           @id @default(uuid()) @db.Uuid
  email           String?          @unique
  pushEndpoint    String?          @unique
  pushP256dh      String?
  pushAuth        String?
  zaloUserId      String?          @unique
  source          String
  preferredNiches String[]         @default([])
  status          SubscriberStatus @default(PENDING)
  confirmedAt     DateTime?
  unsubscribedAt  DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  /// V4: price-drop alerts user này đăng ký (Phase 2).
  priceAlerts     PriceAlert[]

  @@index([source])
  @@index([status])
}

// === STORY-02: Manual sync mode tracking ===
/// LastSyncStatus — 1 row per backbone sync job. `wrap()` ở SyncStatusService update mỗi run.
/// `expectedFrequencySec` dùng để compute `isStale` runtime trong widget admin.
/// Seeded 6 row (4 backbone + 2 money loop sync) ở seed.js.
model LastSyncStatus {
  name                 String    @id
  lastRunAt            DateTime?
  lastSuccessAt        DateTime?
  lastError            String?
  lastDurationMs       Int?
  lastResult           Json?     @db.JsonB
  expectedFrequencySec Int
  isStale              Boolean   @default(false)
  updatedAt            DateTime  @updatedAt

  @@index([isStale])
}

// === STORY-05: Real-bestseller per-order product lines (Loop 2) ===
/// OrderProduct — pulled từ AT `/v1/order-products` cho mỗi ConversionWebhook reconciled.
/// matchedProductId set khi product nội bộ có scrapedData.sourceId khớp atProductId.
model OrderProduct {
  id                  String            @id @default(uuid()) @db.Uuid
  conversionWebhookId String            @db.Uuid
  conversionWebhook   ConversionWebhook @relation(fields: [conversionWebhookId], references: [id], onDelete: Cascade)
  atOrderProductId    String
  atCampaignId        String?
  merchant            String
  atProductId         String?
  productName         String?
  productImage        String?
  productPrice        Float?
  productQuantity     Int?
  approvedQuantity    Int               @default(0)
  pendingQuantity     Int               @default(0)
  rejectQuantity      Int               @default(0)
  approvedBilling     Float             @default(0)
  approvedCommission  Float             @default(0)
  salesTime           DateTime?
  fetchedAt           DateTime          @default(now())
  matchedProductId    String?           @db.Uuid
  matchedProduct      Product?          @relation(fields: [matchedProductId], references: [id], onDelete: SetNull)

  @@unique([conversionWebhookId, atOrderProductId])
  @@index([matchedProductId])
  @@index([salesTime])
}

// === TOOL MODULE: AI-visible decision engine ===
// Tool = interactive quiz/chat → AI recommendation. Niche-agnostic via Json config.
// Khác Article (content) và Product (catalog) — Tool là decision layer.

enum ToolStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Tool — 1 niche có thể có nhiều tool (vd: "Chọn máy lọc nước" + "Tính chi phí 5 năm").
/// quizSchema + scoringRules dạng Json để admin tự soạn qua Tool Builder UI, không cần code.
/// Storefront route: `/tools/[slug]`. Status PUBLISHED mới hiện public.
model Tool {
  id             String        @id @default(uuid()) @db.Uuid
  slug           String        @unique
  nicheId        String        @db.Uuid
  name           String
  description    String?
  /// Tagline hiển thị hero (vd: "AI chọn máy lọc nước trong 60 giây").
  tagline        String?
  /// Quiz schema: list câu hỏi + options + attribute mapping. Cap 3 required + 2 optional.
  /// Shape: { questions: [{ id, question, type, required, options[], defaultValue?, attributeKey, weight }] }
  quizSchema     Json          @db.JsonB
  /// Scoring rules: cách tính score per product. Shape:
  /// { rules: [{ userAttribute, productAttributePath, weight, matchType, params? }] }
  scoringRules   Json          @db.JsonB
  /// Result template: số card hiện, layout, label confidence theo threshold.
  /// Shape: { topN: 3, hierarchy: "1+2" | "equal", confidenceLabels: {high: "Rất phù hợp", ...} }
  resultTemplate Json          @db.JsonB
  status         ToolStatus    @default(DRAFT)
  /// SEO meta riêng cho /tools/[slug].
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  niche          Niche         @relation(fields: [nicheId], references: [id], onDelete: Cascade)
  sessions       QuizSession[]
  clickLogs      ClickLog[]

  @@index([nicheId, status])
  @@index([status])
}

/// QuizSession — mỗi user làm quiz/chat = 1 session. Track full funnel cho analytics.
/// shareSlug cho viral share (/r/[slug]). email capture optional.
model QuizSession {
  id                  String     @id @default(uuid()) @db.Uuid
  toolId              String     @db.Uuid
  /// Raw input: { mode: "chat" | "quiz", chatMessage?, quizAnswers? }
  userInput           Json       @db.JsonB
  /// Parsed structured attributes sau khi AI parse (chat) hoặc form submit (quiz).
  /// Shape: { [attributeKey]: value }
  parsedAttributes    Json       @db.JsonB
  /// Top 3 product ids được recommend, sorted by score desc.
  recommendedProductIds String[] @db.Uuid
  /// AI reasonings per product: { [productId]: { reasoning, fallback, model, confidenceLabel } }
  aiReasonings        Json?      @db.JsonB
  /// utm_source từ URL khi user vào (vd: "tiktok-v1", "fb-group-x", "email-drip-d3").
  source              String?
  /// referrer URL nếu có
  referrer            String?
  /// Email capture (optional, từ inline form Story 4.4).
  email               String?
  /// Short slug cho share link /r/[shareSlug]. 6-8 char.
  shareSlug           String?    @unique
  /// IP hash + UA cho rate limit + analytics (không lưu raw IP).
  ipHash              String?
  userAgent           String?
  /// A/B test flag (Story 6.4): reasoning từ AI thật vs template fallback.
  reasoningMode       String?    // "ai" | "template"
  createdAt           DateTime   @default(now())
  /// Reasoning generation completed time (cho perceived performance metric).
  reasoningReadyAt    DateTime?
  tool                Tool       @relation(fields: [toolId], references: [id], onDelete: Cascade)
  clickLogs           ClickLog[]

  @@index([toolId, createdAt])
  @@index([source])
  @@index([email])
}

/// WaitlistSignup — Epic 0 pre-launch validation. Đo demand trước khi build tool full.
/// Khi tool launch → migrate sang Subscriber (email drip).
model WaitlistSignup {
  id             String   @id @default(uuid()) @db.Uuid
  email          String
  nicheId        String?  @db.Uuid
  nicheSlug      String
  /// Câu khảo sát ngắn (vd: "Bạn đang cần chọn loại nào?")
  surveyAnswer   String?
  /// utm_source: voz | fb-group-x | reddit | ...
  source         String?
  ipHash         String?
  userAgent      String?
  /// Đã được notify khi tool launch chưa.
  notified       Boolean  @default(false)
  notifiedAt     DateTime?
  createdAt      DateTime @default(now())
  niche          Niche?   @relation(fields: [nicheId], references: [id], onDelete: SetNull)

  @@unique([email, nicheSlug])
  @@index([nicheSlug, createdAt])
  @@index([source])
}

/// ReasoningCache — cache AI-generated reasoning per (product × user profile hash).
/// Giảm AI cost 60-70% (user input tương tự → cùng reasoning).
/// TTL 30 ngày qua createdAt (cron clean stale).
model ReasoningCache {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @db.Uuid
  /// sha256(sorted JSON userAttributes). Tune granularity sau khi có 100 session.
  profileHash  String
  /// Generated reasoning text (1-2 câu VN + điểm trừ inline).
  reasoning    String
  /// Model dùng (vd "gemini-2.0-flash") — track cost + invalidate khi đổi model.
  model        String
  /// Số lần hit cache (analytics).
  hitCount     Int      @default(1)
  createdAt    DateTime @default(now())
  lastHitAt    DateTime @default(now())

  @@unique([productId, profileHash, model])
  @@index([productId])
  @@index([createdAt])
}

// === V4: PRICE INTELLIGENCE (moat dữ liệu giá real-time) ===

/// PriceSnapshot — chuỗi giá theo thời gian per Product. Ghi 1 row mỗi crawl cycle khi giá đổi
/// (dedup nếu giá không đổi so với snapshot gần nhất). Nền cho deal verdict (thật/ảo/đáy) + chart.
/// Khác point-in-time `Product.scrapedData.price` — đây là lịch sử để soi anchor giả.
model PriceSnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String   @db.Uuid
  /// Giá hiệu lực (salePrice ?? price) — giá người mua thực trả tại thời điểm capture.
  price         Decimal  @db.Decimal(15, 2)
  /// Giá niêm yết nhà bán công bố (anchor) — để phát hiện "giảm ảo". Null khi không có.
  originalPrice Decimal? @db.Decimal(15, 2)
  currency      String   @default("VND")
  /// Nguồn giá (network/marketplace), vd "ACCESSTRADE". Free text.
  source        String?
  capturedAt    DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, capturedAt])
  @@index([capturedAt])
}

/// PriceAlert — đăng ký theo dõi giá xuống (Phase 2 data). Reuse Subscriber làm danh tính.
/// Notify (push/email) khi giá <= targetPrice, hoặc rớt bất kỳ khi notifyOnAnyDrop=true.
/// Phase 2: chưa wire live-posting (cần credential kênh) — model + service skeleton trước.
model PriceAlert {
  id                String     @id @default(uuid()) @db.Uuid
  productId         String     @db.Uuid
  subscriberId      String     @db.Uuid
  /// Ngưỡng giá muốn được báo. Null + notifyOnAnyDrop=true → báo mọi lần rớt giá.
  targetPrice       Decimal?   @db.Decimal(15, 2)
  notifyOnAnyDrop   Boolean    @default(false)
  isActive          Boolean    @default(true)
  lastNotifiedAt    DateTime?
  lastNotifiedPrice Decimal?   @db.Decimal(15, 2)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  product           Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  subscriber        Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([productId, subscriberId])
  @@index([productId, isActive])
  @@index([subscriberId])
}

