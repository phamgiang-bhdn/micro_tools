generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NicheStatus {
  ACTIVE
  INACTIVE
}

enum ParseStatus {
  DRAFT_RAW
  PENDING_REVIEW
  PUBLISHED
  ERROR
}

enum ArticleType {
  BUYING_GUIDE
  REVIEW
}

enum ArticleStatus {
  // Legacy (kept for backward compat with v1 articles)
  GENERATING
  DRAFT
  // V2 pipeline states
  DRAFT_BRIEF
  RESEARCHING
  REVIEWS_SCRAPED
  OUTLINE_READY
  IMAGES_READY
  DRAFTING
  SELF_CRITIQUED
  FACT_CHECKED
  PENDING_REVIEW
  NEEDS_REVISION
  // Terminal
  PUBLISHED
  ARCHIVED
  FAILED
}

enum EvidenceType {
  FACT
  REVIEW
  PRICE
  SPEC
  IMAGE
  NEWS
}

enum AffiliateNetwork {
  ACCESSTRADE
  SHOPEE
  TIKTOK
  LAZADA
}

enum CampaignStatus {
  APPLIED
  APPROVED
  REJECTED
  PAUSED
  INACTIVE
}

model CrawlerLog {
  id            String   @id @default(uuid()) @db.Uuid
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  fetched       Int      @default(0)
  passedFilter  Int      @default(0)
  created       Int      @default(0)
  updated       Int      @default(0)
  skipped       Int      @default(0)
  success       Boolean  @default(false)
  errorReason   String?
  durationMs    Int?
  triggeredBy   String?

  @@index([startedAt])
}

/// Campaign = mỗi merchant trên một affiliate network (Accesstrade Shopee CPS, Lazada CPS...).
/// Cron crawler tự upsert khi gặp campaign mới trong datafeed (status = APPLIED mặc định).
/// Admin sync tay status APPROVED/REJECTED/PAUSED dựa trên dashboard publisher của network.
model Campaign {
  id              String              @id @default(uuid()) @db.Uuid
  network         AffiliateNetwork
  /// @deprecated dùng atCampaignId thay thế (sprint at-source-of-truth STORY-02).
  /// Giữ để backward compat với row legacy (campaign tạo trước sprint, externalId = slugify(name)).
  /// Khi tất cả campaign đã backfill atCampaignId → cân nhắc drop (xem docs/sprints/at-source-of-truth/FUTURE-DROPS.md).
  externalId      String
  name            String
  merchantName    String?
  status          CampaignStatus      @default(APPLIED)
  appliedAt       DateTime?
  approvedAt      DateTime?
  commissionNote  String?
  notes           String?
  atCampaignId        String?    @unique
  atCategoryName      String?
  atSubCategory       String?
  atLogo              String?
  atMerchantUrl       String?
  atScope             String?
  atCookieDurationSec Int?
  atStartTime         DateTime?
  atEndTime           DateTime?
  atRawData           Json?      @db.JsonB
  atLastSyncedAt      DateTime?
  /// Per-campaign filter rules. Validate qua `filterRulesSchema`.
  /// Khi null/empty → crawler dùng DEFAULT_FILTER_RULES.
  filterRules     Json?               @db.JsonB
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  products        Product[]
  conversions     ConversionWebhook[]
  coupons         Coupon[]

  @@unique([network, externalId])
  @@index([status])
  @@index([network, status])
  @@index([atCampaignId])
}

model Coupon {
  id              String          @id @default(uuid()) @db.Uuid
  code            String          @unique
  description     String?
  discountPercent Int?
  discountAmount  Decimal?        @db.Decimal(10, 2)
  network         AffiliateNetwork?
  productId       String?         @db.Uuid
  nicheId         String?         @db.Uuid
  campaignId      String?         @db.Uuid
  affiliateUrl    String?
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean         @default(true)
  atCouponId      String?         @unique
  merchantSlug    String?
  merchantDisplay String?
  merchantLogo    String?
  iconText        String?
  iconTextId      String?
  contentHtml     String?
  imageUrl        String?
  bannersJson     Json?           @db.JsonB
  domain          String?
  prodLink        String?
  coinCap         Decimal?        @db.Decimal(15, 2)
  coinPercentage  Decimal?        @db.Decimal(5, 2)
  percentageUsed  Decimal?        @db.Decimal(5, 2)
  atRawData       Json?           @db.JsonB
  atLastSyncedAt  DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  niche           Niche?          @relation(fields: [nicheId], references: [id], onDelete: SetNull)
  campaign        Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([isActive, expiresAt])
  @@index([nicheId, isActive])
  @@index([productId, isActive])
  @@index([merchantSlug, isActive])
  @@index([atLastSyncedAt])
  @@index([campaignId])
}

model Niche {
  id              String      @id @default(uuid()) @db.Uuid
  slug            String      @unique
  name            String
  status          NicheStatus @default(ACTIVE)
  schemaConfig    Json
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  products        Product[]
  articles        Article[]
  coupons         Coupon[]
}

/// AT taxonomy bucket — auto-populated từ `offer.atCategorySlug` (raw AT `cate`).
/// Mỗi offer crawled tự upsert 1 row Category theo `slug` (normalized).
/// `displayName` admin tự điền sau — storefront chỉ filter theo Category có displayName.
/// KHÔNG phải Niche (Niche = SEO/curate layer, Category = AT raw taxonomy để admin lọc sản phẩm).
model Category {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  rawValue    String
  displayName String?
  source      String   @default("accesstrade")
  createdAt   DateTime @default(now())
  products    Product[]
}

/// "Nơi bán" — auto-populated từ hostname của `offer.affiliateUrl` (vd "shopee.vn", "lazada.vn").
/// Mỗi domain unique → 1 row Source. Admin điền `displayName` ("Shopee VN", "Lazada VN") sau.
/// Storefront chỉ hiện Source có displayName trong filter (hide khi null).
model Source {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  rawValue    String
  displayName String?
  source      String   @default("accesstrade")
  createdAt   DateTime @default(now())
  products    Product[]
}

/// "Domain" — auto-populated từ `offer.domain` (vd "shopee.vn", "lazada.vn").
/// Mỗi domain unique → 1 row Brand. Admin điền `displayName` ("Shopee Vietnam") sau.
/// Storefront chỉ hiện row có displayName trong filter (hide khi null).
/// **Lưu ý**: model name vẫn là `Brand` để tránh refactor lớn; ngữ nghĩa hiện tại là Domain.
model Brand {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  rawValue    String
  displayName String?
  source      String   @default("accesstrade")
  createdAt   DateTime @default(now())
  products    Product[]
}

/// Shop — admin tự tạo + gán tay cho từng Product (AT KHÔNG trả shop info).
/// Khác Domain (Brand): Domain là technical (auto từ offer.domain); Shop là cửa hàng cụ thể admin quản lý.
/// Hiển thị trên storefront thay cho campaign info.
model Shop {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  name        String
  description String?
  logoUrl     String?
  websiteUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

model Product {
  id           String     @id @default(uuid()) @db.Uuid
  /// Niche assigned by admin (PR4 — manual gán tay). NULL = chưa gán → ẩn khỏi storefront.
  /// Crawler KHÔNG tự gán nicheId; admin assign trong /admin/products (bulk hoặc per-row).
  nicheId      String?    @db.Uuid
  /// AT taxonomy bucket (PR2). Auto-populated từ `offer.atCategorySlug`. Khác `nicheId` (SEO layer).
  categoryId   String?    @db.Uuid
  /// Nơi bán (PR3). Auto-populated từ hostname của `affiliateUrl`.
  sourceId     String?    @db.Uuid
  /// Domain (model name `Brand` legacy). Auto-populated từ `offer.domain` (vd "shopee.vn").
  brandId      String?    @db.Uuid
  /// Shop — admin gán tay (AT không trả). NULL = chưa gán.
  shopId       String?    @db.Uuid
  network      AffiliateNetwork @default(ACCESSTRADE)
  campaignId   String?    @db.Uuid
  name         String
  slug         String?
  affiliateUrl String
  scrapedData  Json       @db.JsonB
  isPublic     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  niche        Niche?     @relation(fields: [nicheId], references: [id], onDelete: SetNull)
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  source       Source?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  brand        Brand?     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  shop         Shop?      @relation(fields: [shopId], references: [id], onDelete: SetNull)
  campaign     Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  clickLogs    ClickLog[]
  extractions  ProductExtraction[]
  coupons      Coupon[]
  reviews      ProductReview[]

  @@unique([nicheId, slug])
  @@index([nicheId])
  @@index([campaignId])
  @@index([categoryId])
  @@index([sourceId])
  @@index([brandId])
  @@index([shopId])
}

model ClickLog {
  id              String              @id @default(uuid()) @db.Uuid
  productId       String              @db.Uuid
  trackingCode    String              @unique
  ipHash          String
  userAgent       String?
  createdAt       DateTime            @default(now())
  product         Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  conversionHooks ConversionWebhook[]

  @@index([productId, createdAt])
}

model ConversionWebhook {
  id               String           @id @default(uuid()) @db.Uuid
  trackingCode     String
  network          AffiliateNetwork @default(ACCESSTRADE)
  campaignId       String?          @db.Uuid
  revenue          Decimal          @db.Decimal(10, 2)
  status           String
  payload          Json             @db.JsonB
  source           String?          @default("webhook")
  lastReconciledAt DateTime?
  atOrderId        String?
  atCommission     Decimal?         @db.Decimal(10, 2)
  reconcileNotes   String?
  receivedAt       DateTime         @default(now())
  clickLog         ClickLog         @relation(fields: [trackingCode], references: [trackingCode], onDelete: Restrict)
  campaign         Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([trackingCode, receivedAt])
  @@index([network, receivedAt])
  @@index([campaignId, receivedAt])
  @@index([atOrderId])
  @@index([lastReconciledAt])
}

model TopProductSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  snapshotDate    DateTime
  position        Int
  atProductId     String
  name            String
  brand           String?
  image           String?
  link            String
  affLink         String
  categoryName    String?
  productCategory String?
  price           Decimal?  @db.Decimal(15, 2)
  discount        Decimal?  @db.Decimal(15, 2)
  merchant        String?
  shortDesc       String?
  atRawData       Json?     @db.JsonB
  createdAt       DateTime  @default(now())

  @@unique([snapshotDate, position, atProductId])
  @@index([snapshotDate])
  @@index([merchant, snapshotDate])
}

model ReconciliationLog {
  id              String   @id @default(uuid()) @db.Uuid
  triggeredBy     String
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  syncWindowStart DateTime
  syncWindowEnd   DateTime
  fetched         Int      @default(0)
  matched         Int      @default(0)
  updated         Int      @default(0)
  unmatched       Int      @default(0)
  success         Boolean  @default(false)
  errorReason     String?
  durationMs      Int?

  @@index([startedAt])
}

model ProductExtraction {
  id              String      @id @default(uuid()) @db.Uuid
  productId       String      @db.Uuid
  rawContent      String
  aiOutput        Json?       @db.JsonB
  status          ParseStatus @default(DRAFT_RAW)
  errorReason     String?
  reviewedBy      String?
  reviewedAt      DateTime?
  sourceUrl       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, status, createdAt])
}

model PromptTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  content     String
  isActive    Boolean  @default(false)
  version     Int      @default(1)
  createdBy   String?
  createdAt   DateTime @default(now())
  activatedAt DateTime?
}

model Article {
  id              String        @id @default(uuid()) @db.Uuid
  slug            String        @unique
  title           String
  excerpt         String?
  body            String
  blocks          Json?         @db.JsonB
  coverImage      String?
  type            ArticleType
  status          ArticleStatus @default(DRAFT)
  nicheId         String?       @db.Uuid
  productIds      String[]      @db.Uuid
  pinnedProductIds String[]     @db.Uuid
  metaTitle       String?
  metaDescription String?
  aiModel         String?
  aiPromptName    String?
  generationError String?
  reviewedBy      String?
  reviewedAt      DateTime?
  scheduledAt     DateTime?
  publishedAt     DateTime?
  // V2 pipeline fields
  briefJson       Json?         @db.JsonB
  outlineJson     Json?         @db.JsonB
  authorId        String?       @db.Uuid
  layoutVariant   String?
  wordCount       Int?
  readabilityScore Float?
  evidenceFreshAt DateTime?
  revisionCount   Int           @default(0)
  aiRevisionCount Int           @default(0)
  thesisEmbedding Float[]
  coverImageAttribution Json?   @db.JsonB
  currentStageMessage String?
  currentStageProgress Int?
  currentStageStartedAt DateTime?
  /// Khi true: pipeline dừng sau OUTLINE (status=IMAGES_READY) để admin duyệt/sửa outline
  /// trước khi tốn 5-10 phút Writer chạy. Admin bấm "Tiếp tục viết" → set false + tiếp tục.
  pauseAtOutline   Boolean       @default(false)
  topic           String?
  productRef      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  niche           Niche?        @relation(fields: [nicheId], references: [id], onDelete: SetNull)
  author          Author?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  sections        ArticleSection[]
  evidence        ArticleEvidence[]
  runs            ArticleGenerationRun[]

  @@index([status, publishedAt])
  @@index([nicheId, status])
  @@index([type, status])
  @@index([scheduledAt])
  @@index([authorId])
  @@index([evidenceFreshAt])
}

/// Author — định danh tác giả của Article V2. voiceProfile (Json) inject vào Writer prompt
/// để chống mono-voice. expertiseNiches dùng cho round-robin rotation.
model Author {
  id              String   @id @default(uuid()) @db.Uuid
  slug            String   @unique
  name            String
  bio             String?
  avatarUrl       String?
  voiceProfile    Json     @db.JsonB
  expertiseNiches String[] @db.Uuid
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  articles        Article[]

  @@index([isActive])
}

/// ArticleSection — đơn vị tổ chức bài V2. Article có nhiều section, mỗi section là khối
/// blocks (giống schema cũ) + summary cho TOC + evidence refs. Render storefront chia section
/// có anchor để TOC nhảy. Status per-section cho HITL approve granular.
model ArticleSection {
  id              String   @id @default(uuid()) @db.Uuid
  articleId       String   @db.Uuid
  anchorSlug      String
  heading         String
  summary         String
  intent          String?
  order           Int
  blocks          Json     @db.JsonB
  blockTypeHints  String[]
  evidenceRefs    String[] @db.Uuid
  wordCount       Int      @default(0)
  estimatedWords  Int      @default(0)
  isRequired      Boolean  @default(true)
  status          String   @default("DRAFTING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, anchorSlug])
  @@index([articleId, order])
}

/// ArticleEvidence — moat chính chống thin-content. Mỗi claim/fact/review/price/image phải
/// có evidence cite được. Fact-check loop verify sourceUrl còn live và content khớp.
model ArticleEvidence {
  id              String       @id @default(uuid()) @db.Uuid
  articleId       String       @db.Uuid
  type            EvidenceType
  productId       String?      @db.Uuid
  sourceUrl       String
  sourceDomain    String
  title           String?
  payload         Json         @db.JsonB
  contentHash     String
  fetchedAt       DateTime     @default(now())
  expiresAt       DateTime?
  factCheckPassed Boolean      @default(false)
  factCheckedAt   DateTime?
  article         Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, type])
  @@index([contentHash])
  @@index([sourceDomain])
  @@index([productId])
}

/// ProductReview — user review thật cào từ Accesstrade / Shopee / Tiki / Lazada.
/// Đây là "original research signal" cho EEAT. Article có thể cite vào block review_quote.
model ProductReview {
  id              String    @id @default(uuid()) @db.Uuid
  productId       String    @db.Uuid
  source          String
  sourceUrl       String?
  author          String?
  rating          Decimal?  @db.Decimal(3, 2)
  title           String?
  body            String
  verifiedBuyer   Boolean   @default(false)
  reviewDate      DateTime?
  scrapedAt       DateTime  @default(now())
  sentiment       String?
  topicTags       String[]
  raw             Json?     @db.JsonB
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, source])
  @@index([productId, rating])
  @@index([productId, sentiment])
}

/// ArticleGenerationRun — observability log per stage execution. Cho phép retry stage lẻ,
/// debug cost, track duration. Inspect qua admin dashboard.
model ArticleGenerationRun {
  id            String   @id @default(uuid()) @db.Uuid
  articleId     String   @db.Uuid
  stage         String
  agent         String
  model         String?
  promptName    String?
  inputHash     String?
  inputSize     Int?
  outputSize    Int?
  output        Json?     @db.JsonB
  durationMs    Int?
  costEstimate  Decimal?  @db.Decimal(10, 6)
  success       Boolean   @default(false)
  errorReason   String?
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  article       Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, startedAt])
  @@index([stage, success])
}
